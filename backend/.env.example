# App
APP_NAME=OntoForge API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

# Neo4j (optional; if omitted, graph sync endpoints stay disabled)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Extraction pipeline options
SPACY_MODEL=en_core_web_sm
ENABLE_TRANSFORMERS=false
TRANSFORMER_NER_MODEL=Jean-Baptiste/roberta-large-ner-english

# Optional OpenAI-compatible chat completion endpoint for relation canonicalization
# Example: https://api.openai.com/v1/chat/completions
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# Security / persistence
DATABASE_URL=sqlite:///data/app.db
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_MINUTES=60
REDIS_URL=redis://localhost:6379/0

# Optional enterprise integrations
OBJECT_STORAGE_ENDPOINT=
SEARCH_URL=http://localhost:9200
LLM_PROVIDER=none
