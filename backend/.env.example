# App
APP_NAME=OntoForge API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

# Neo4j (optional; if omitted, graph sync endpoints stay disabled)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Extraction pipeline options
SPACY_MODEL=en_core_web_sm
ENABLE_TRANSFORMERS=true
TRANSFORMER_NER_MODEL=Jean-Baptiste/roberta-large-ner-english

# Optional OpenAI-compatible chat completion endpoint for relation canonicalization
# Example: https://api.openai.com/v1/chat/completions
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
