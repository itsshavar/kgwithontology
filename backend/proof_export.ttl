@prefix meta: <https://ontoforge.local/meta/> .
@prefix ns1: <https://ontoforge.local/project/1/schema/property/> .
@prefix of: <https://ontoforge.local/project/1/> .
@prefix ofe: <https://ontoforge.local/project/1/entity/> .
@prefix ofr: <https://ontoforge.local/project/1/relation/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

of:ontology a owl:Ontology ;
    rdfs:label "Proof Project" ;
    rdfs:comment "Proof run" .

ofr:1 a meta:RelationInstance ;
    rdfs:comment "Alice works for Acme Labs." ;
    meta:object ofe:2-acme-labs ;
    meta:predicate ns1:1-works-for ;
    meta:sourceDocumentId 1 ;
    meta:subject ofe:1-alice .

ofr:2 a meta:RelationInstance ;
    rdfs:comment "Updated evidence text" ;
    meta:objectLiteral "alice@example"^^xsd:string ;
    meta:predicate ns1:3-email ;
    meta:sourceDocumentId 1 ;
    meta:subject ofe:1-alice .

ns1:2-memberof a owl:ObjectProperty ;
    rdfs:label "memberOf" ;
    rdfs:domain <https://ontoforge.local/project/1/schema/class/1-person> ;
    rdfs:range <https://ontoforge.local/project/1/schema/class/2-organization> .

<https://ontoforge.local/project/1/schema/class/2-organization> a owl:Class ;
    rdfs:label "Organization" ;
    meta:source "rdf-import" ;
    meta:status "imported" .

ns1:1-works-for a owl:ObjectProperty ;
    rdfs:label "Works For" ;
    rdfs:comment "Updated property description" ;
    rdfs:domain <https://ontoforge.local/project/1/schema/class/1-person> .

ns1:3-email a owl:DatatypeProperty ;
    rdfs:label "Email" ;
    rdfs:comment "Auto-created from extraction phrase 'email'." ;
    rdfs:domain <https://ontoforge.local/project/1/schema/class/3-researcher> ;
    rdfs:range xsd:string .

ofe:1-alice a <https://ontoforge.local/project/1/schema/class/3-researcher> ;
    rdfs:label "Alice" ;
    meta:source "auto-extracted" ;
    ns1:1-works-for ofe:2-acme-labs ;
    ns1:3-email "alice@example"^^xsd:string .

ofe:2-acme-labs rdfs:label "Acme Labs" ;
    meta:source "auto-extracted" .

<https://ontoforge.local/project/1/schema/class/3-researcher> a owl:Class ;
    rdfs:label "Researcher" ;
    rdfs:subClassOf <https://ontoforge.local/project/1/schema/class/1-person> ;
    meta:source "rdf-import" ;
    meta:status "imported" .

<https://ontoforge.local/project/1/schema/class/1-person> a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "Updated human class description" ;
    meta:source "rdf-import" ;
    meta:status "imported" .

